# -----------------------------------------------
# AI-Powered HTTP Request Analyzer – Environment
# -----------------------------------------------
# Copy this file to `.env` and fill in your values.

# Google GenAI (Gemini 2.5 Flash)
GOOGLE_API_KEY=

# Redis
REDIS_URL=redis://localhost:60379/0
REDIS_PORT=60379

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=waf_payloads
RAG_ENABLED=true
GATEKEEPER_ENABLED=true

# Flask App
APP_PORT=5000

# Batch Processing (async worker)
BATCH_MAX_SIZE=20
BATCH_WINDOW_SECONDS=10.0
BATCH_QUEUE_KEY=waf:queue:llm_analysis
BATCH_DLQ_KEY=waf:queue:llm_analysis_dlq
BATCH_RESULT_TTL=3600
