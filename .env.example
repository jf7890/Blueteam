# -----------------------------------------------
# BlueAgent WAF – Docker Compose Environment
# -----------------------------------------------
# Copy this file to `.env` and fill in your values.
# These variables are referenced by docker-compose.yaml.

DEBUG=false
DEBUG_CSV_PATH=logs/debug_pipeline.csv

# ========================== LLM ==========================
# Google GenAI API key (required)
GOOGLE_API_KEY=

# ========================== Redis ========================
# Internal Docker network URL (override only if using external Redis)
REDIS_URL=redis://redis:6379/0

# ========================== Qdrant =======================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=waf_payloads
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
RAG_ENABLED=true

# Dense embedding model for RAG vector search
RAG_DENSE_MODEL=jinaai/jina-embeddings-v2-base-code

# ========================== Flask App ====================
APP_PORT=5000

# ========================== Persistence ==================
SQLITE_DB_PATH=data/copilot_data.db
SIEM_LOG_PATH=logs/ai_alerts.jsonl

# Host directory bind-mounted to /app/logs (readable by Wazuh agent)
LOG_DIR=./logs

# ========================== Batch Processing =============
BATCH_MAX_SIZE=20
BATCH_WINDOW_SECONDS=10.0
BATCH_QUEUE_KEY=waf:queue:llm_analysis
BATCH_DLQ_KEY=waf:queue:llm_analysis_dlq
BATCH_RESULT_TTL=3600

# ========================== http.ingest ==================
# Host port exposed for the ingest service
INGEST_PORT=60085
